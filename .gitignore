.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Project specific
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Track model binaries, metadata and evaluation reports
models/*
!models/.gitkeep
!models/credit_risk_model.joblib
!models/model_metadata.json
!models/evaluation/
!models/evaluation/*

# Do not ignore specific joblib and pkl files inside models directory
!models/**/*.joblib
!models/**/*.pkl

# Local runtime logs
logs/*
!logs/.gitkeep

